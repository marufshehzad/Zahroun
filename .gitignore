# ============================================================
# Zahroun — production .gitignore
# ============================================================

# Dependencies
node_modules/

# Secrets / environment (NEVER commit these)
.env
.env.*
*.key
serviceAccountKey.json
.devtest/serviceAccount.json

# Dev/test scaffolding (never deploy)
.devtest/
.claude/
.vs/
.vscode/
.idea/
sandbox/

# Backups & temp artifacts
.backup/
backups/
seo_backup/
*.bak
*.bak-*
*.tmp
tmp/
cache/
logs/
*.log
screenshots/

# Dev-only pages (not for production)
seed.html
test_images.html
migrate-firestore.html
product pictures/oita kajj kortese*

# Platform
.netlify/

# OS junk
.DS_Store
Thumbs.db
