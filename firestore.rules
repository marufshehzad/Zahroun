rules_version = '2';

/* =========================================================================
   ZAHROUN — Firestore Security Rules
   =========================================================================
   HOW TO PUBLISH:
   1. Firebase Console -> Build -> Firestore Database -> "Rules" tab
   2. Replace everything there with the contents of this file
   3. Click "Publish"

   Model:
   - Public can READ products / categories / coupons / reviews (storefront)
   - Only signed-in users can place orders & manage their own data
   - Only ADMINS (users/{uid}.role == "admin") can manage the catalog & orders
   ========================================================================= */

service cloud.firestore {
  match /databases/{database}/documents {

    function isSignedIn() {
      return request.auth != null;
    }

    function isOwner(uid) {
      return isSignedIn() && request.auth.uid == uid;
    }

    // Admin check via Firestore role field — add new admins by setting users/{uid}.role = "admin"
    function isAdmin() {
      return isSignedIn()
        && get(/databases/$(database)/documents/users/$(request.auth.uid)).data.role == "admin";
    }

    // ---- User profiles -------------------------------------------------
    match /users/{uid} {
      allow read:   if isOwner(uid) || isAdmin();
      allow create: if isOwner(uid);
      // A user may update their own profile but must NOT escalate their role.
      allow update: if (isOwner(uid) && request.resource.data.role == resource.data.role)
                    || isAdmin();
      allow delete: if isAdmin();
    }

    // ---- Catalog (public read, admin write) ----------------------------
    match /products/{id} {
      allow read:  if true;
      allow write: if isAdmin();
    }
    match /categories/{id} {
      allow read:  if true;
      allow write: if isAdmin();
    }
    match /coupons/{id} {
      allow read:  if true;
      allow create, delete: if isAdmin();
      // Admin can update anything; anyone (incl. guests) can only increment usedCount
      allow update: if isAdmin()
                    || request.resource.data.diff(resource.data).affectedKeys().hasOnly(['usedCount']);
    }

    // ---- Orders --------------------------------------------------------
    match /orders/{id} {
      // Logged-in: uid must match auth uid
      // Guest: isGuest==true and uid==null (no account required)
      allow create: if (isSignedIn() && request.resource.data.uid == request.auth.uid)
                    || (!isSignedIn() && request.resource.data.isGuest == true
                        && request.resource.data.uid == null);
      allow read:   if isAdmin() || (isSignedIn() && resource.data.uid == request.auth.uid) || true;
      allow update, delete: if isAdmin();
    }

    // ---- Reviews -------------------------------------------------------
    match /reviews/{id} {
      allow read:   if true;
      allow create: if isSignedIn() && request.resource.data.uid == request.auth.uid;
      allow update, delete: if isAdmin()
                    || (isSignedIn() && resource.data.uid == request.auth.uid);
    }

    // ---- Wishlist (one doc per user) -----------------------------------
    match /wishlist/{uid} {
      allow read, write: if isOwner(uid);
    }

    // ---- Site settings (homepage, banners) -----------------------------
    match /settings/{id} {
      allow read:  if true;
      allow write: if isAdmin();
    }

    // ---- Newsletter / contact submissions ------------------------------
    match /newsletter/{id} {
      allow create: if true;          // anyone can subscribe
      allow read, update, delete: if isAdmin();
    }
    match /messages/{id} {
      allow create: if true;          // anyone can send a contact message
      allow read, update, delete: if isAdmin();
    }

    // ---- FAQs (public read, admin write) ----------------------------------
    match /faqs/{id} {
      allow read: if true;
      allow write: if isAdmin();
    }

    // ---- Stock history log (admin write, no customer access) ---------------
    match /stockHistory/{id} {
      allow read, write: if isAdmin();
    }

    // ---- Bundle deals (public read, admin write) ----------------------------
    match /bundles/{id} {
      allow read:  if true;
      allow write: if isAdmin();
    }

    // ---- Loyalty points (owner read/write, admin full access) ---------------
    match /loyaltyPoints/{uid} {
      allow read:   if isOwner(uid) || isAdmin();
      allow write:  if isOwner(uid) || isAdmin();
    }

    // ---- Loyalty history log (owner read, admin full) -----------------------
    match /loyaltyHistory/{id} {
      allow read:   if isAdmin() || (isSignedIn() && resource.data.uid == request.auth.uid);
      allow create: if isAdmin() || (isSignedIn() && request.resource.data.uid == request.auth.uid);
      allow update, delete: if isAdmin();
    }

    // ---- Referral codes (owner read/write, public code lookup for validation)
    match /referrals/{uid} {
      allow read:   if true;
      allow create: if isOwner(uid) || isAdmin();
      allow update: if isOwner(uid) || isAdmin();
      allow delete: if isAdmin();
    }
  }
}
